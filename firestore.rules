rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny rule as global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Hardened Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email_verified == true && (
          request.auth.token.email.toLowerCase() == 'charlesadu3112@gmail.com' ||
          request.auth.token.email.toLowerCase() == 'admin@jaypictures.com'
        )) || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Specific Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             (data.role == 'admin' || data.role == 'client') &&
             data.createdAt == request.time;
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'durationMinutes', 'isActive', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             (data.price is number || data.price is int) && data.price >= 0 &&
             data.durationMinutes is int && data.durationMinutes > 0 &&
             data.isActive is bool &&
             data.createdAt == request.time;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['clientId', 'serviceId', 'bookingDate', 'status', 'totalAmount', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 7 &&
             data.clientId is string && isValidId(data.clientId) &&
             data.serviceId is string && isValidId(data.serviceId) &&
             data.bookingDate is string && data.bookingDate.size() <= 100 &&
             (data.status == 'pending' || data.status == 'confirmed' || data.status == 'completed' || data.status == 'cancelled') &&
             (data.totalAmount is number || data.totalAmount is int) && data.totalAmount >= 0;
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['bookingId', 'clientId', 'amount', 'currency', 'status', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.bookingId is string && isValidId(data.bookingId) &&
             data.clientId is string && isValidId(data.clientId) &&
             (data.amount is number || data.amount is int) && data.amount >= 0 &&
             data.currency is string && data.currency.size() == 3 &&
             (data.status == 'pending' || data.status == 'paid' || data.status == 'failed' || data.status == 'refunded');
    }

    function isValidGallery(data) {
      return data.keys().hasAll(['bookingId', 'clientId', 'title', 'photos', 'isPrivate', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.bookingId is string && isValidId(data.bookingId) &&
             data.clientId is string && isValidId(data.clientId) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.photos is list && data.photos.size() <= 200 &&
             (data.photos.size() == 0 || (data.photos.size() > 0 && data.photos[0] is string)) &&
             data.isPrivate is bool;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['clientId', 'bookingId', 'fullName', 'rating', 'feedback', 'isApproved', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.clientId is string && isValidId(data.clientId) &&
             data.bookingId is string && isValidId(data.bookingId) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200 &&
             data.rating is int && data.rating >= 1 && data.rating <= 5 &&
             data.feedback is string && data.feedback.size() > 0 && data.feedback.size() <= 2000 &&
             data.isApproved is bool;
    }

    function isValidAvailability(data) {
      return data.keys().hasAll(['date', 'time', 'isBooked']) &&
             (data.keys().size() == 3 || (data.keys().size() == 4 && data.keys().hasAll(['bookingId']))) &&
             data.date is string && data.date.size() == 10 &&
             data.time is string && data.time.size() == 5 &&
             data.isBooked is bool;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['recipientId', 'title', 'message', 'isRead', 'type', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.recipientId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.isRead is bool &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 100;
    }

    function isValidInspiration(data) {
      return data.keys().hasAll(['clientId', 'imageUrl', 'title', 'conceptNotes', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.clientId is string && isValidId(data.clientId) &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 1000 &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.conceptNotes is string && data.conceptNotes.size() > 0 && data.conceptNotes.size() <= 2000;
    }

    // --- Match Rules ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin(); // Users should not blanket read profiles
      
      allow create: if isSignedIn() && isValidId(userId) && (
        (isOwner(userId) && isValidUser(incoming()) && (incoming().role == 'client' || incoming().role == 'admin')) ||
        isAdmin()
      );
      
      allow update: if isSignedIn() && isValidId(userId) && (
        isAdmin() ||
        (isOwner(userId) && isValidUser(incoming()) &&
         incoming().role == existing().role &&
         incoming().createdAt == existing().createdAt && (
           incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'email'])
         )
        )
      );
      
      allow delete: if isAdmin() && isValidId(userId);
    }

    // SERVICES COLLECTION
    match /services/{serviceId} {
      allow read: if true; // Public package browsing
      
      allow create: if (isAdmin() || isSignedIn()) && isValidId(serviceId) && isValidService(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      allow delete: if isAdmin() && isValidId(serviceId);
    }

    // BOOKINGS COLLECTION
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && isValidId(bookingId) && (resource.data.clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidId(bookingId) && isValidBooking(incoming()) && (
        (incoming().clientId == request.auth.uid && incoming().status == 'pending' && incoming().createdAt == request.time && incoming().updatedAt == request.time &&
         exists(/databases/$(database)/documents/users/$(incoming().clientId)) &&
         exists(/databases/$(database)/documents/services/$(incoming().serviceId))) ||
        isAdmin()
      );
      
      allow update: if isSignedIn() && isValidId(bookingId) && (
        isAdmin() ||
        (resource.data.clientId == request.auth.uid && isValidBooking(incoming()) &&
         incoming().clientId == existing().clientId &&
         incoming().serviceId == existing().serviceId &&
         incoming().createdAt == existing().createdAt &&
         incoming().updatedAt == request.time &&
         existing().status != 'completed' && existing().status != 'cancelled' && (
           // Action: Cancel booking
           (incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
           // Action: Reschedule booking
           (incoming().status == existing().status && incoming().diff(existing()).affectedKeys().hasOnly(['bookingDate', 'updatedAt']))
         )
        )
      );
      
      allow delete: if isAdmin() && isValidId(bookingId);
    }

    // PAYMENTS COLLECTION
    match /payments/{paymentId} {
      allow get: if isSignedIn() && isValidId(paymentId) && (resource.data.clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidId(paymentId) && isValidPayment(incoming()) && (
        isAdmin() ||
        (incoming().clientId == request.auth.uid && incoming().createdAt == request.time &&
         exists(/databases/$(database)/documents/bookings/$(incoming().bookingId)) &&
         get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.clientId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin() && isValidId(paymentId);
    }

    // GALLERIES COLLECTION
    match /galleries/{galleryId} {
      allow get: if isValidId(galleryId) && (
        !resource.data.isPrivate || 
        (isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin()))
      );
      allow list: if (
        !resource.data.isPrivate || 
        (isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin()))
      );
      
      allow create: if isAdmin() && isValidId(galleryId) && isValidGallery(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidId(galleryId) && isValidGallery(incoming());
      allow delete: if isAdmin() && isValidId(galleryId);
    }

    // TESTIMONIALS COLLECTION
    match /testimonials/{testimonialId} {
      allow get: if isValidId(testimonialId) && (
        resource.data.isApproved == true || 
        (isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin()))
      );
      allow list: if (
        resource.data.isApproved == true || 
        (isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin()))
      );
      
      allow create: if isSignedIn() && isValidId(testimonialId) && isValidTestimonial(incoming()) && (
        isAdmin() ||
        (incoming().clientId == request.auth.uid && incoming().isApproved == false && incoming().createdAt == request.time &&
         exists(/databases/$(database)/documents/bookings/$(incoming().bookingId)) &&
         get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.clientId == request.auth.uid)
      );
      
      allow update: if isSignedIn() && isValidId(testimonialId) && (
        isAdmin() ||
        (resource.data.clientId == request.auth.uid && isValidTestimonial(incoming()) &&
         incoming().clientId == existing().clientId &&
         incoming().bookingId == existing().bookingId &&
         incoming().createdAt == existing().createdAt &&
         incoming().isApproved == false && (
           incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'feedback'])
         )
        )
      );
      
      allow delete: if isAdmin() || (isSignedIn() && isValidId(testimonialId) && resource.data.clientId == request.auth.uid && resource.data.isApproved == false);
    }

    // AVAILABILITY COLLECTION
    match /availability/{slotId} {
      allow read: if true; // Picker is public
      allow create: if isValidId(slotId) && isValidAvailability(incoming()) && (
        isAdmin() ||
        (isSignedIn() && incoming().isBooked == true && incoming().bookingId is string &&
         exists(/databases/$(database)/documents/bookings/$(incoming().bookingId)) &&
         get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.clientId == request.auth.uid)
      );
      allow update: if isValidId(slotId) && (
        isAdmin() ||
        (isSignedIn() && isValidAvailability(incoming()) &&
         incoming().date == existing().date &&
         incoming().time == existing().time && (
           // Action: Book standard slot
           (incoming().isBooked == true && existing().isBooked == false &&
            incoming().diff(existing()).affectedKeys().hasOnly(['isBooked', 'bookingId']) &&
            exists(/databases/$(database)/documents/bookings/$(incoming().bookingId)) &&
            get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.clientId == request.auth.uid) ||
           // Action: Release/Cancel standard slot
           (incoming().isBooked == false && existing().isBooked == true &&
            incoming().diff(existing()).affectedKeys().hasOnly(['isBooked', 'bookingId']) &&
            get(/databases/$(database)/documents/bookings/$(existing().bookingId)).data.clientId == request.auth.uid)
         )
        )
      );
      allow delete: if isAdmin() && isValidId(slotId);
    }

    // NOTIFICATIONS COLLECTION
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && isValidId(notificationId) && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'admin' || isAdmin());
      allow list: if isSignedIn() && (resource.data.recipientId == request.auth.uid || resource.data.recipientId == 'admin' || isAdmin());
      
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming()) && (
        isAdmin() ||
        (incoming().recipientId == 'admin' && incoming().isRead == false && incoming().createdAt == request.time)
      );
      
      allow update: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming()) && (
        isAdmin() ||
        ((resource.data.recipientId == request.auth.uid || (resource.data.recipientId == 'admin' && isAdmin())) &&
         incoming().recipientId == existing().recipientId &&
         incoming().title == existing().title &&
         incoming().message == existing().message &&
         incoming().type == existing().type &&
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['isRead'])
        )
      );
      
      allow delete: if isSignedIn() && isValidId(notificationId) && (resource.data.recipientId == request.auth.uid || isAdmin());
    }

    // INSPIRATIONS COLLECTION
    match /inspirations/{inspirationId} {
      allow get: if isSignedIn() && isValidId(inspirationId) && (resource.data.clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidId(inspirationId) && isValidInspiration(incoming()) && (
        isAdmin() ||
        (incoming().clientId == request.auth.uid && incoming().createdAt == request.time)
      );
      
      allow update: if isSignedIn() && isValidId(inspirationId) && isValidInspiration(incoming()) && (
        isAdmin() ||
        (resource.data.clientId == request.auth.uid &&
         incoming().clientId == existing().clientId &&
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['imageUrl', 'title', 'conceptNotes'])
        )
      );
      
      allow delete: if isSignedIn() && isValidId(inspirationId) && (resource.data.clientId == request.auth.uid || isAdmin());
    }

  }
}
